{
  "name": "repolens-ai",
  "version": "3.1.2",
  "description": "The Context Quality Guardian for AI Coding Agents - AST-powered analysis, drift detection, cross-tool sync",
  "author": "harry-kien <kientrantrung3@gmail.com>",
  "license": "MIT",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "repolens": "dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "npm run typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "prepublishOnly": "npm run lint && npm run test && npm run build"
  },
  "keywords": [
    "ai",
    "agents-md",
    "claude-md",
    "cursorrules",
    "ai-context",
    "vibe-coding",
    "context-quality",
    "context-engineering",
    "ai-coding-agent",
    "prompt-engineering",
    "ai-code-review",
    "agentic-coding",
    "ast-analysis",
    "drift-detection",
    "github-action",
    "developer-tools",
    "static-analysis"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Harry-Kien/repolens-ai.git"
  },
  "homepage": "https://github.com/Harry-Kien/repolens-ai#readme",
  "bugs": {
    "url": "https://github.com/Harry-Kien/repolens-ai/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "ora": "^8.1.1",
    "ts-morph": "^28.0.0"
  },
  "optionalDependencies": {
    "openai": "^4.73.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@vitest/coverage-v8": "^4.1.6",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^4.1.6"
  }
}
